# 本地开发环境变量
# 复制: copy .env.example .env  (Windows) 或 cp .env.example .env (Linux/macOS)
# Docker Compose 启动 MySQL/Redis 后，使用下方「Docker 本地开发」配置

# ── Docker 本地开发（docker compose up -d mysql redis）──
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=paper_writer
DB_PASS=db-secret-change-me
DB_NAME=paper_writer
REDIS_URL=redis://127.0.0.1:6379

# ── 本机 MySQL（不用 Docker 时取消注释并修改）──
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASS=your-mysql-password
# DB_NAME=paper_writer
# REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters
JWT_EXPIRES=7200

# App
PORT=3000
NODE_ENV=development

# LLM (inherited from core)
INKOS_LLM_API_KEY=sk-...
INKOS_LLM_MODEL=deepseek-v4-flash
INKOS_LLM_BASE_URL=https://api.deepseek.com/anthropic
