{
  "name": "@actalk/inkos-core",
  "version": "1.3.10",
  "description": "InkOS Paper — AI academic paper writing pipeline with topic brainstorming, literature search, outline generation, section writing, and AI-detection evasion",
  "keywords": [
    "ai-paper-writing",
    "academic-writing",
    "ai-detection-evasion",
    "paper-generator",
    "literature-review",
    "citation-formatter",
    "multi-agent-pipeline",
    "llm-agent",
    "zod-validation"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "genres"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Narcooo/inkos.git",
    "directory": "packages/core"
  },
  "scripts": {
    "prepack": "node ../../scripts/prepare-package-for-publish.mjs",
    "postpack": "node ../../scripts/restore-package-json.mjs",
    "prepublishOnly": "node ../../scripts/verify-no-workspace-protocol.mjs .",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.67.1",
    "@mariozechner/pi-ai": "^0.67.1",
    "adm-zip": "^0.5.17",
    "docx": "^9.6.1",
    "dotenv": "^16.4.0",
    "fast-xml-parser": "^5.7.3",
    "undici": "6.21.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
